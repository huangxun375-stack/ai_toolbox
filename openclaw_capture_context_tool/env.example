# Copy this file to .env.
# openclaw_capture_toolkit.sh auto-loads .env in the same directory.

# Toolkit runtime
STATE_DIR=./.state

# In portable bundle mode this defaults to ./capture_tool.
# CAPTURE_TOOL_DIR=./capture_tool
CAPTURE_DATA_DIR=./data/context_capture_live

# Network and ports
MITM_HOST=127.0.0.1
MITM_PORT=18080
CAPTURE_API_HOST=0.0.0.0
CAPTURE_API_PORT=8000
CAPTURE_PROXY_URL=http://127.0.0.1:18080
CAPTURE_API_URL=http://127.0.0.1:8000

# OpenClaw gateway
GATEWAY_BASE_URL=http://127.0.0.1:28789
OPENCLAW_CONFIG=$HOME/.openclaw/openclaw.json
OPENCLAW_GATEWAY_BIND=loopback
# OPENCLAW_BIN=openclaw
# If openclaw is not in PATH, point to the local openclaw.mjs file:
# OPENCLAW_BIN=/abs/path/to/openclaw.mjs
# Optional: explicit token (otherwise auto-read from running process/config)
# GATEWAY_TOKEN=

# Optional binaries
MITMDUMP_BIN=
CAPTURE_API_PYTHON=

# Optional URL prefix filter for mitmproxy (empty = capture all traffic)
CONTEXT_CAPTURE_HTTP_URL_PREFIX=
GATEWAY_LOG=./.state/openclaw_gateway_capture.log

# Default payload for toolkit "request" command
REQUEST_MODEL=gpt-4.1-mini
REQUEST_PROMPT='请只回复: OK'
REQUEST_USER=capture-tool
REQUEST_USE_PROXY=1
REQUEST_TIMEOUT=120
